---
import BaseLayout from './BaseLayout.astro';
import type { CollectionEntry } from 'astro:content';

interface Props {
  project: CollectionEntry<'projects'>;
}

const { project } = Astro.props;
const { title, summary, stack, status, date, links } = project.data;

const formatted = new Intl.DateTimeFormat('en-US', {
  year: 'numeric',
  month: 'long',
}).format(date);

const statusLabel: Record<string, string> = {
  shipped: 'Shipped',
  'in-progress': 'In Progress',
  archived: 'Archived',
};
---

<BaseLayout title={`${title} | Shane Kanterman`} description={summary}>
  <!-- Backdrop -->
  <div class="fixed inset-0 pointer-events-none z-0" aria-hidden="true">
    <div
      class="absolute w-[34rem] h-[34rem] rounded-full blur-[120px] opacity-15"
      style="top:-10rem;left:-8rem;background:#7a8fa8;"
    ></div>
    <div
      class="absolute w-[34rem] h-[34rem] rounded-full blur-[120px] opacity-15"
      style="top:20rem;right:-10rem;background:#8da4b8;"
    ></div>
    <div
      class="absolute inset-0"
      style="
        background-image:linear-gradient(rgba(255,255,255,0.018) 1px,transparent 1px),linear-gradient(90deg,rgba(255,255,255,0.018) 1px,transparent 1px);
        background-size:54px 54px;
        mask-image:radial-gradient(circle at top,black 28%,transparent 82%);
      "
    ></div>
  </div>

  <div class="relative z-10 w-[min(calc(100%-2rem),1240px)] mx-auto pb-24">
    <!-- Header -->
    <header class="sticky top-4 z-20 pt-4">
      <div
        class="glass flex items-center justify-between gap-4 px-5 py-4 rounded-full"
      >
        <a
          class="inline-flex items-center gap-3.5 min-w-0"
          href="/"
          aria-label="Shane Kanterman home"
        >
          <span
            class="inline-flex items-center justify-center w-11 h-11 rounded-full font-extrabold text-sm tracking-widest text-[#04101d] flex-shrink-0"
            style="background:var(--accent-gradient);"
          >
            SK
          </span>
          <span class="flex flex-col min-w-0">
            <strong class="text-[0.95rem] leading-tight">Shane Kanterman</strong>
            <span class="text-[0.76rem] leading-tight text-[#6e7f99] max-[600px]:hidden">
              Infrastructure and Web Projects
            </span>
          </span>
        </a>

        <a
          href="/#projects"
          class="inline-flex items-center gap-2 text-[#a0afc4] hover:text-[#f1f4f9] transition-colors duration-[180ms] text-sm font-medium"
        >
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M19 12H5M12 5l-7 7 7 7"/>
          </svg>
          All projects
        </a>
      </div>
    </header>

    <main class="pt-16 max-w-[780px] mx-auto">
      <!-- Project header -->
      <div class="mb-14">
        <div class="flex flex-wrap items-center gap-3 mb-6">
          <span class="text-[#94a3b8] text-[0.82rem] font-bold tracking-[0.16em] uppercase">
            Case Study
          </span>
          <span class="w-px h-4 bg-[rgba(148,163,184,0.3)]" aria-hidden="true"></span>
          <span class="text-[#6e7f99] text-[0.82rem]">{formatted}</span>
          <span class="w-px h-4 bg-[rgba(148,163,184,0.3)]" aria-hidden="true"></span>
          <span
            class="inline-flex items-center gap-1.5 text-[0.8rem] font-medium"
            class:list={[
              status === 'shipped' ? 'text-[#86efac]' : '',
              status === 'in-progress' ? 'text-[#fcd34d]' : '',
              status === 'archived' ? 'text-[#6e7f99]' : '',
            ]}
          >
            <span
              class="w-1.5 h-1.5 rounded-full"
              class:list={[
                status === 'shipped' ? 'bg-[#86efac]' : '',
                status === 'in-progress' ? 'bg-[#fcd34d]' : '',
                status === 'archived' ? 'bg-[#6e7f99]' : '',
              ]}
            ></span>
            {statusLabel[status]}
          </span>
        </div>

        <h1
          class="text-[clamp(2.2rem,4vw,3.5rem)] leading-[1.06] tracking-[-0.04em] font-extrabold mb-6"
        >
          {title}
        </h1>

        <p class="text-[#a0afc4] text-[1.1rem] leading-[1.75] mb-8 max-w-[60ch]">
          {summary}
        </p>

        <!-- Stack -->
        <div class="flex flex-wrap gap-2 mb-8">
          {stack.map((item) => (
            <span class="inline-flex items-center min-h-8 px-3 py-1.5 rounded-full border border-[rgba(148,163,184,0.18)] bg-[rgba(148,163,184,0.08)] text-[#d8e0ec] text-[0.8rem] font-medium">
              {item}
            </span>
          ))}
        </div>

        <!-- Links -->
        {links && links.length > 0 && (
          <div class="flex flex-wrap gap-3">
            {links.map((link) => (
              <a
                href={link.href}
                target="_blank"
                rel="noopener"
                class="btn btn-secondary text-sm"
              >
                {link.label}
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/>
                  <polyline points="15 3 21 3 21 9"/>
                  <line x1="10" y1="14" x2="21" y2="3"/>
                </svg>
              </a>
            ))}
          </div>
        )}

        <div class="mt-10 border-t border-[rgba(148,163,184,0.14)]"></div>
      </div>

      <!-- MDX prose body -->
      <div class="prose">
        <slot />
      </div>

      <!-- Footer nav -->
      <div class="mt-20 pt-8 border-t border-[rgba(148,163,184,0.14)]">
        <a
          href="/#projects"
          class="inline-flex items-center gap-2 text-[#a0afc4] hover:text-[#f1f4f9] transition-colors duration-[180ms] font-medium"
        >
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M19 12H5M12 5l-7 7 7 7"/>
          </svg>
          Back to all projects
        </a>
      </div>
    </main>
  </div>
</BaseLayout>
