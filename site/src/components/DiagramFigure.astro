---
interface Props {
  src: string;
  alt: string;
  caption?: string;
  /** 'wide' breaks out of prose column slightly for large diagrams */
  wide?: boolean;
}

const { src, alt, caption, wide = false } = Astro.props;

// Unique id so multiple diagrams on one page don't collide
const id = `diagram-${Math.random().toString(36).slice(2, 8)}`;
---

<figure
  class:list={[
    'my-10 not-prose',
    wide ? '-mx-8 max-[600px]:mx-0' : '',
  ]}
>
  <!-- Trigger -->
  <button
    class="diagram-trigger glass overflow-hidden w-full p-0 border-0 cursor-zoom-in relative group block"
    aria-label={`Expand diagram: ${alt}`}
    data-dialog-id={id}
    type="button"
  >
    <img
      src={src}
      alt={alt}
      class="w-full h-auto block"
      loading="lazy"
      decoding="async"
    />
    <!-- Zoom hint overlay -->
    <span
      class="absolute bottom-3 right-3 flex items-center gap-1.5 px-2.5 py-1.5 rounded-lg text-[0.72rem] font-medium text-[#d8e0ec] opacity-0 group-hover:opacity-100 transition-opacity duration-200 pointer-events-none"
      style="background:rgba(10,18,32,0.78);backdrop-filter:blur(6px);border:1px solid rgba(148,163,184,0.2);"
      aria-hidden="true"
    >
      <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
        <circle cx="11" cy="11" r="8"/>
        <line x1="21" y1="21" x2="16.65" y2="16.65"/>
        <line x1="11" y1="8" x2="11" y2="14"/>
        <line x1="8" y1="11" x2="14" y2="11"/>
      </svg>
      Expand
    </span>
  </button>

  {caption && (
    <figcaption class="mt-3 text-center text-[0.82rem] text-[#6e7f99] leading-relaxed px-4">
      {caption}
    </figcaption>
  )}
</figure>

<!-- Lightbox dialog -->
<dialog
  id={id}
  class="diagram-dialog"
  aria-label={alt}
>
  <button
    class="diagram-dialog-close"
    aria-label="Close"
    data-close-dialog={id}
    type="button"
  >
    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
      <line x1="18" y1="6" x2="6" y2="18"/>
      <line x1="6" y1="6" x2="18" y2="18"/>
    </svg>
  </button>

  <div class="diagram-dialog-inner">
    <img
      src={src}
      alt={alt}
      class="diagram-dialog-img"
      decoding="async"
    />
    {caption && (
      <p class="diagram-dialog-caption">{caption}</p>
    )}
  </div>
</dialog>

<style>
  /* ── Trigger ── */
  .diagram-trigger {
    border-radius: var(--radius-md);
    background: var(--panel);
    border: 1px solid var(--line);
    box-shadow: var(--shadow);
    backdrop-filter: blur(14px);
    -webkit-backdrop-filter: blur(14px);
  }

  .diagram-trigger:focus-visible {
    outline: 2px solid #94a3b8;
    outline-offset: 3px;
  }

  /* ── Dialog backdrop + box ── */
  .diagram-dialog {
    position: fixed;
    inset: 0;
    width: 100%;
    height: 100%;
    max-width: 100%;
    max-height: 100%;
    margin: 0;
    padding: 0;
    border: none;
    background: transparent;
    display: flex;
    align-items: center;
    justify-content: center;
    z-index: 100;
  }

  .diagram-dialog::backdrop {
    background: rgba(4, 9, 18, 0.88);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
  }

  /* hidden state — dialog[open] is set by JS */
  .diagram-dialog:not([open]) {
    display: none;
  }

  /* ── Inner wrapper ── */
  .diagram-dialog-inner {
    position: relative;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1rem;
    max-width: min(92vw, 1100px);
    max-height: 92vh;
    padding: 1rem;
    animation: dialog-in 200ms ease;
  }

  @keyframes dialog-in {
    from { opacity: 0; transform: scale(0.97); }
    to   { opacity: 1; transform: scale(1); }
  }

  /* ── Image ── */
  .diagram-dialog-img {
    display: block;
    max-width: 100%;
    max-height: calc(92vh - 4rem);
    width: auto;
    height: auto;
    object-fit: contain;
    border-radius: 16px;
    border: 1px solid rgba(148, 163, 184, 0.18);
    box-shadow: 0 32px 80px rgba(0, 0, 0, 0.5);
    cursor: zoom-out;
  }

  /* ── Caption ── */
  .diagram-dialog-caption {
    color: #6e7f99;
    font-size: 0.82rem;
    text-align: center;
    line-height: 1.5;
    margin: 0;
  }

  /* ── Close button ── */
  .diagram-dialog-close {
    position: fixed;
    top: 1.25rem;
    right: 1.25rem;
    display: flex;
    align-items: center;
    justify-content: center;
    width: 2.5rem;
    height: 2.5rem;
    border-radius: 999px;
    border: 1px solid rgba(148, 163, 184, 0.22);
    background: rgba(10, 18, 32, 0.82);
    color: #a0afc4;
    cursor: pointer;
    transition: color 150ms ease, background 150ms ease, border-color 150ms ease;
    z-index: 101;
  }

  .diagram-dialog-close:hover {
    color: #f1f4f9;
    background: rgba(20, 30, 50, 0.95);
    border-color: rgba(148, 163, 184, 0.4);
  }

  .diagram-dialog-close:focus-visible {
    outline: 2px solid #94a3b8;
    outline-offset: 3px;
  }
</style>

<script>
  // Wire up every trigger/dialog pair on the page
  document.querySelectorAll<HTMLButtonElement>('.diagram-trigger').forEach((trigger) => {
    const dialogId = trigger.getAttribute('data-dialog-id');
    if (!dialogId) return;
    const dialog = document.getElementById(dialogId) as HTMLDialogElement | null;
    if (!dialog) return;

    // Open on trigger click
    trigger.addEventListener('click', () => {
      dialog.showModal();
      document.body.style.overflow = 'hidden';
    });

    // Close on backdrop click (click outside the inner wrapper)
    dialog.addEventListener('click', (e: MouseEvent) => {
      const inner = dialog.querySelector('.diagram-dialog-inner');
      if (inner && !inner.contains(e.target as Node)) {
        dialog.close();
        document.body.style.overflow = '';
      }
    });

    // Close on image click (zoom-out feel)
    const img = dialog.querySelector<HTMLImageElement>('.diagram-dialog-img');
    img?.addEventListener('click', () => {
      dialog.close();
      document.body.style.overflow = '';
    });

    // Close button
    const closeBtn = dialog.querySelector<HTMLButtonElement>(`[data-close-dialog="${dialogId}"]`);
    closeBtn?.addEventListener('click', () => {
      dialog.close();
      document.body.style.overflow = '';
    });

    // Escape is handled natively by <dialog> — just restore scroll
    dialog.addEventListener('close', () => {
      document.body.style.overflow = '';
    });
  });
</script>
