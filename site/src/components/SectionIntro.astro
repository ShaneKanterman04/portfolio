---
interface Props {
  eyebrow: string;
  title: string;
  body: string;
  class?: string;
}

const { eyebrow, title, body, class: className = '' } = Astro.props;
---

<div class={`max-w-[48rem] mb-12 max-[780px]:mb-9 ${className}`}>
  <p class="mb-4 text-[#71717a] text-[0.82rem] font-bold tracking-[0.16em] uppercase">{eyebrow}</p>
  <h2
    class="text-[clamp(2rem,4.1vw,3rem)] leading-[1.08] tracking-[-0.02em] mb-5 font-extrabold text-[#18181b] max-[780px]:text-[clamp(1.9rem,8vw,2.6rem)]"
  >
    {title}
  </h2>
  <p class="text-[#52525b] leading-[1.75] text-[1.04rem]">{body}</p>
</div>
