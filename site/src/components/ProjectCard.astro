---
import type { CollectionEntry } from 'astro:content';
import GlassCard from './GlassCard.astro';
import StackBadge from './StackBadge.astro';

interface Props {
  project: CollectionEntry<'projects'>;
  featured?: boolean;
}

const { project, featured = false } = Astro.props;

const statusLabel: Record<(typeof project.data.status), string> = {
  shipped: 'Shipped',
  'in-progress': 'In Progress',
  archived: 'Archived',
};
---

<GlassCard class="p-8 overflow-wrap-break-word min-w-0 max-[780px]:p-6" hover={true}>
  <div class="flex flex-wrap items-start justify-between gap-3 mb-4">
    <div class="flex flex-wrap items-center gap-2.5">
      <p class="text-[#71717a] text-[0.78rem] font-bold tracking-[0.14em] uppercase">
        {featured ? 'Featured case study' : 'Case study'}
      </p>
      <span class="project-meta-badge">{statusLabel[project.data.status]}</span>
    </div>
    <div class="flex flex-wrap gap-2">
      {project.data.stack.map((item) => (
        <StackBadge label={item} />
      ))}
    </div>
  </div>

  <h3 class="text-[1.28rem] leading-[1.25] tracking-[-0.01em] font-bold mb-3 text-[#18181b]">
    {project.data.title}
  </h3>
  <p class="text-[#52525b] leading-[1.75] text-[1.04rem]">{project.data.summary}</p>

  <div class={`project-proof-grid ${featured ? 'project-proof-grid-featured' : ''}`}>
    <div>
      <p class="project-proof-label">Highlight</p>
      <p class="project-proof-copy">{project.data.highlight}</p>
    </div>
    <div>
      <p class="project-proof-label">Impact</p>
      <p class="project-proof-copy">{project.data.impact}</p>
    </div>
    <div>
      <p class="project-proof-label">Constraint</p>
      <p class="project-proof-copy">{project.data.constraint}</p>
    </div>
  </div>

  <div class="mt-6">
    <a
      href={`/projects/${project.id}`}
      class="inline-flex items-center gap-2 text-[#1e293b] hover:text-[#0f172a] transition-colors duration-[180ms] font-medium"
    >
      {featured ? 'Read deployment case study' : 'See project breakdown'}
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <path d="M7 17L17 7" />
        <path d="M9 7h8v8" />
      </svg>
    </a>
  </div>
</GlassCard>
