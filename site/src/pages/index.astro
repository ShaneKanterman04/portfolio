---
import AnimatedSection from '../components/AnimatedSection.astro';
import BaseLayout from '../layouts/BaseLayout.astro';
import GlassCard from '../components/GlassCard.astro';
import ProjectCard from '../components/ProjectCard.astro';
import SectionIntro from '../components/SectionIntro.astro';
import SiteHeader from '../components/SiteHeader.astro';
import StackBadge from '../components/StackBadge.astro';
import { getCollection } from 'astro:content';

const allProjects = await getCollection('projects');
const sorted = allProjects.sort((a, b) => a.data.order - b.data.order);
const featuredProject = sorted.find((project) => project.data.featured)!;
const supportingProjects = sorted.filter((project) => !project.data.featured);

const navItems = [
  { label: 'About', href: '#about' },
  { label: 'Projects', href: '#projects' },
  { label: 'Skills', href: '#skills' },
  { label: 'Contact', href: '#contact' },
];

const capabilityGroups = [
  {
    name: 'Infrastructure',
    description: 'Systems work, hosting, and platform fundamentals.',
    items: ['Linux', 'Nginx', 'Google Cloud', 'Terraform', 'Proxmox', 'PXE Boot'],
  },
  {
    name: 'Development',
    description: 'Frontend and scripting tools used to build and ship projects.',
    items: ['Astro', 'HTML', 'CSS', 'JavaScript', 'Python', 'Git'],
  },
  {
    name: 'Operations',
    description: 'Workflow, deployment, and practical day-to-day tooling.',
    items: ['GitHub Actions', 'SSH', 'Virtualization', 'Windows', 'Containers'],
  },
];

const heroFacts = [
  'Computer Science student at Southern Connecticut State University',
  'Hands-on data center internship experience at InterServer',
  'Portfolio shipped as a static site with cloud infrastructure behind it',
];

const heroMetrics = [
  { value: '2 VMs', label: 'Cloud deployment' },
  { value: 'Static Astro', label: 'Fast static frontend' },
  { value: 'GitHub CI/CD', label: 'Automated delivery' },
];

const profilePoints = [
  'Rack-and-stack and server deployment experience',
  'Linux administration and troubleshooting background',
  'Self-hosted systems for development, backups, and web app hosting',
];
---

<BaseLayout
  title="Shane Kanterman | Infrastructure and Web Projects"
  description="Portfolio site for Shane Kanterman, a Computer Science student with hands-on Linux, server deployment, and cloud-hosted web project experience."
>
  <div
    class="relative z-10 w-[min(calc(100%-2rem),1240px)] mx-auto pb-20 max-[780px]:w-[min(calc(100%-2rem),1240px)]"
  >
    <SiteHeader home={true} navItems={navItems} />

    <main class="pt-8" id="main-content">
      <section
        class="grid grid-cols-[minmax(0,1.15fr)_minmax(18rem,24rem)] gap-10 items-start min-h-[calc(100vh-8rem)] pt-6 pb-20 scroll-mt-[10.5rem] max-[960px]:grid-cols-1 max-[960px]:min-h-0 max-[960px]:pt-9 max-[960px]:pb-11"
        id="top"
      >
        <div>
          <p class="mb-4 text-[#71717a] text-[0.82rem] font-bold tracking-[0.16em] uppercase">
            Computer Science Student
          </p>
          <h1
            class="text-[clamp(2.6rem,4.5vw,4.2rem)] leading-[1.06] tracking-[-0.02em] mb-5 max-w-[14ch] font-extrabold overflow-wrap-break-word text-[#18181b]"
          >
            Building <span class="gradient-text">reliable web systems</span> with a practical
            infrastructure background.
          </h1>
          <p class="text-[#52525b] leading-[1.75] text-[1.04rem] max-w-[48rem]">
            I build projects that connect frontend delivery with real hosting, deployment, and
            operational thinking. This portfolio is designed to show both the code and the systems
            mindset behind it.
          </p>

          <div class="flex flex-wrap gap-4 mt-8 max-[780px]:flex-col max-[780px]:items-stretch">
            <a class="btn btn-primary" href="#projects">
              View Projects
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M7 17L17 7" />
                <path d="M9 7h8v8" />
              </svg>
            </a>
            <a
              class="btn btn-secondary"
              href="https://www.linkedin.com/in/shane-kanterman-4511a2234"
              target="_blank"
              rel="noopener noreferrer"
            >
              LinkedIn
            </a>
          </div>
        </div>

        <GlassCard class="sticky top-28 flex flex-col gap-8 p-8 max-[960px]:static" hover={false}>
          <div>
            <p class="mb-4 text-[#71717a] text-[0.78rem] font-bold tracking-[0.14em] uppercase">
              Current focus
            </p>
            <ul class="grid gap-4 p-0 list-none">
              {heroFacts.map((fact) => (
                <li class="relative pl-5 text-[#52525b] leading-[1.6] text-[0.95rem]">
                  <span
                    class="absolute left-0 top-[0.72rem] -translate-y-1/2 w-1.5 h-1.5 rounded-full"
                    style="background:#1e293b;box-shadow:0 0 0 4px rgba(30,41,59,0.08);"
                    aria-hidden="true"
                  ></span>
                  {fact}
                </li>
              ))}
            </ul>
          </div>

          <div class="grid gap-2.5 pt-5 border-t border-[rgba(0,0,0,0.08)]">
            {heroMetrics.map((metric) => (
              <div class="flex justify-between items-baseline gap-4 overflow-wrap-break-word">
                <span class="text-[0.93rem] font-bold text-[#18181b] leading-snug shrink-0">
                  {metric.value}
                </span>
                <span class="text-[0.82rem] text-[#71717a] leading-snug text-right">
                  {metric.label}
                </span>
              </div>
            ))}
          </div>
        </GlassCard>
      </section>

      <AnimatedSection
        class="observe-animate pt-28 pb-8 scroll-mt-[10.5rem] max-[960px]:pt-[5.25rem] max-[960px]:pb-6"
        id="about"
        delay={1}
      >
        <SectionIntro
          eyebrow="About"
          title="From data center work to software projects."
          body="My background is rooted in infrastructure, deployment, and systems work. I am growing that into software development by building projects that are designed, shipped, and run like real products."
        />

        <div
          class="grid grid-cols-[minmax(0,1.5fr)_minmax(18rem,1fr)] gap-5 max-[960px]:grid-cols-1"
        >
          <GlassCard class="grid gap-5 p-8 overflow-wrap-break-word min-w-0 max-[780px]:p-6" hover={true}>
            <p class="text-[#52525b] leading-[1.75] text-[1.04rem]">
              I am a Computer Science student at Southern Connecticut State University with hands-on
              experience in rack-and-stack, server deployment, PXE boot imaging, Linux
              administration, and hardware troubleshooting.
            </p>
            <p class="text-[#52525b] leading-[1.75] text-[1.04rem]">
              I completed a data center internship at InterServer and continue building my skills
              through self-hosted systems for remote development, backups, and web app hosting.
            </p>
          </GlassCard>

          <GlassCard class="p-8 overflow-wrap-break-word min-w-0 max-[780px]:p-6" hover={true}>
            <p class="mb-4 text-[#71717a] text-[0.78rem] font-bold tracking-[0.14em] uppercase">
              What that looks like
            </p>
            <ul class="grid gap-4 p-0 list-none">
              {profilePoints.map((point) => (
                <li class="relative pl-5 text-[#52525b] leading-[1.6] text-[0.95rem]">
                  <span
                    class="absolute left-0 top-[0.72rem] -translate-y-1/2 w-1.5 h-1.5 rounded-full"
                    style="background:#1e293b;box-shadow:0 0 0 4px rgba(30,41,59,0.08);"
                    aria-hidden="true"
                  ></span>
                  {point}
                </li>
              ))}
            </ul>
          </GlassCard>
        </div>
      </AnimatedSection>

      <AnimatedSection
        class="observe-animate pt-28 pb-8 scroll-mt-[10.5rem] max-[960px]:pt-[5.25rem] max-[960px]:pb-6"
        id="projects"
        delay={1}
      >
        <SectionIntro
          eyebrow="Projects"
          title="Work that shows how I build and deploy."
          body="The strongest projects here are the ones that combine implementation with hosting, automation, and operational discipline."
          class="mb-11"
        />

        <div class="grid gap-5">
          <ProjectCard project={featuredProject} featured={true} />

          <div class="grid grid-cols-2 gap-5 max-[960px]:grid-cols-1">
            {supportingProjects.map((project) => (
              <ProjectCard project={project} />
            ))}
          </div>
        </div>
      </AnimatedSection>

      <AnimatedSection
        class="observe-animate pt-28 pb-8 scroll-mt-[10.5rem] max-[960px]:pt-[5.25rem] max-[960px]:pb-6"
        id="skills"
        delay={1}
      >
        <SectionIntro
          eyebrow="Skills"
          title="Current tools and areas of focus."
          body="The goal is not just to know tools, but to use them together to ship dependable work."
        />

        <div class="grid grid-cols-3 gap-5 max-[960px]:grid-cols-2 max-[580px]:grid-cols-1">
          {capabilityGroups.map((group) => (
            <GlassCard
              class="grid content-start gap-4 p-8 min-h-full overflow-wrap-break-word min-w-0 max-[780px]:p-6"
              hover={true}
            >
              <p class="text-[#71717a] text-[0.78rem] font-bold tracking-[0.14em] uppercase">
                {group.name}
              </p>
              <p class="text-[#52525b] leading-[1.75] text-[1.04rem]">{group.description}</p>
              <div class="flex flex-wrap gap-2">
                {group.items.map((item) => (
                  <StackBadge label={item} />
                ))}
              </div>
            </GlassCard>
          ))}
        </div>
      </AnimatedSection>

      <AnimatedSection
        class="observe-animate pt-28 pb-8 scroll-mt-[10.5rem] max-[960px]:pt-[5.25rem] max-[960px]:pb-6"
        id="contact"
        delay={1}
      >
        <GlassCard
          class="grid grid-cols-[minmax(0,1.4fr)_auto] gap-10 items-center p-8 overflow-wrap-break-word min-w-0 max-[960px]:grid-cols-1 max-[780px]:p-6"
          hover={false}
        >
          <div class="max-w-[38rem]">
            <p class="mb-4 text-[#71717a] text-[0.82rem] font-bold tracking-[0.16em] uppercase">
              Contact
            </p>
            <h2
              class="text-[clamp(2rem,4.1vw,3rem)] leading-[1.08] tracking-[-0.02em] mb-5 font-extrabold text-[#18181b] max-[780px]:text-[clamp(1.9rem,8vw,2.6rem)]"
            >
              Open to technical opportunities and connections.
            </h2>
            <p class="text-[#52525b] leading-[1.75] text-[1.04rem]">
              I am currently open to part-time, contract, and junior roles related to
              infrastructure, deployment, and software development.
            </p>
          </div>

          <div class="max-[780px]:w-full">
            <a
              class="btn btn-primary max-[780px]:w-full"
              href="https://www.linkedin.com/in/shane-kanterman-4511a2234"
              target="_blank"
              rel="noopener noreferrer"
            >
              Connect on LinkedIn
            </a>
          </div>
        </GlassCard>
      </AnimatedSection>

      <footer class="pt-18 pb-0 text-center text-[#a1a1aa] text-[0.88rem]">
        <p>© {new Date().getFullYear()} Shane Kanterman. Built with Astro and deployed on GCP.</p>
      </footer>
    </main>
  </div>

  <script>
    const header = document.getElementById('header');
    const mobileToggle = document.querySelector('.mobile-toggle');
    const mobileNav = document.getElementById('mobile-nav');
    const sectionIds = ['about', 'projects', 'skills', 'contact'];
    const sectionLinks = Array.from(document.querySelectorAll('[data-nav-link]'));
    const mobileBreakpoint = window.matchMedia('(min-width: 781px)');

    let scrollFrame = 0;

    const syncHeader = () => {
      if (!header) return;
      header.classList.toggle('is-scrolled', window.scrollY > 12);
      scrollFrame = 0;
    };

    const requestHeaderSync = () => {
      if (scrollFrame !== 0) return;
      scrollFrame = window.requestAnimationFrame(syncHeader);
    };

    syncHeader();
    window.addEventListener('scroll', requestHeaderSync, { passive: true });

    const setActiveSection = (sectionId) => {
      sectionLinks.forEach((link) => {
        const isActive = link.getAttribute('data-nav-link') === sectionId;
        if (isActive) {
          link.setAttribute('aria-current', 'location');
        } else {
          link.removeAttribute('aria-current');
        }
      });
    };

    if ('IntersectionObserver' in window) {
      const observer = new IntersectionObserver(
        (entries) => {
          const visibleEntries = entries
            .filter((entry) => entry.isIntersecting)
            .sort((a, b) => b.intersectionRatio - a.intersectionRatio);

          if (visibleEntries.length > 0) {
            setActiveSection(visibleEntries[0].target.id);
          }
        },
        {
          rootMargin: '-35% 0px -45% 0px',
          threshold: [0.2, 0.4, 0.6],
        },
      );

      sectionIds.forEach((id) => {
        const section = document.getElementById(id);
        if (section) observer.observe(section);
      });
    }

    if (mobileToggle instanceof HTMLButtonElement && mobileNav instanceof HTMLElement) {
      const iconBars = mobileToggle.querySelectorAll('span:not(.sr-only)');

      const renderMenuState = (open) => {
        mobileToggle.setAttribute('aria-expanded', String(open));
        mobileNav.classList.toggle('is-open', open);

        if (open) {
          iconBars[0]?.style.setProperty('transform', 'translateY(8px) rotate(45deg)');
          iconBars[1]?.style.setProperty('opacity', '0');
          iconBars[2]?.style.setProperty('transform', 'translateY(-8px) rotate(-45deg)');
        } else {
          iconBars[0]?.style.removeProperty('transform');
          iconBars[1]?.style.removeProperty('opacity');
          iconBars[2]?.style.removeProperty('transform');
        }
      };

      const closeMenu = (restoreFocus = true) => {
        renderMenuState(false);
        if (restoreFocus) mobileToggle.focus();
      };

      renderMenuState(false);

      mobileToggle.addEventListener('click', () => {
        const shouldOpen = mobileToggle.getAttribute('aria-expanded') !== 'true';
        renderMenuState(shouldOpen);

        if (shouldOpen) {
          const firstLink = mobileNav.querySelector('a');
          firstLink?.focus();
        }
      });

      mobileNav.querySelectorAll('a').forEach((link) => {
        link.addEventListener('click', () => {
          closeMenu(false);
        });
      });

      document.addEventListener('keydown', (event) => {
        if (event.key === 'Escape' && mobileToggle.getAttribute('aria-expanded') === 'true') {
          closeMenu();
        }
      });

      mobileBreakpoint.addEventListener('change', (event) => {
        if (event.matches) {
          closeMenu(false);
        }
      });
    }
  </script>
</BaseLayout>
