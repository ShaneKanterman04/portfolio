---
import AnimatedSection from '../components/AnimatedSection.astro';
import BaseLayout from '../layouts/BaseLayout.astro';
import GlassCard from '../components/GlassCard.astro';
import { getCollection } from 'astro:content';

const allProjects = await getCollection('projects');
const sorted = allProjects.sort((a, b) => a.data.order - b.data.order);
const featuredProject = sorted.find((project) => project.data.featured)!;
const supportingProjects = sorted.filter((project) => !project.data.featured);

const capabilityGroups = [
  {
    name: 'Infrastructure',
    description: 'Systems work, hosting, and platform fundamentals.',
    items: ['Linux', 'Nginx', 'Google Cloud', 'Terraform', 'Proxmox', 'PXE Boot'],
  },
  {
    name: 'Development',
    description: 'Frontend and scripting tools used to build and ship projects.',
    items: ['Astro', 'HTML', 'CSS', 'JavaScript', 'Python', 'Git'],
  },
  {
    name: 'Operations',
    description: 'Workflow, deployment, and practical day-to-day tooling.',
    items: ['GitHub Actions', 'SSH', 'Virtualization', 'Windows', 'Containers'],
  },
];

const heroFacts = [
  'Computer Science student at Southern Connecticut State University',
  'Hands-on data center internship experience at InterServer',
  'Portfolio shipped as a static site with cloud infrastructure behind it',
];

const heroMetrics = [
  { value: '2 VMs', label: 'Cloud deployment' },
  { value: 'Static Astro', label: 'Fast static frontend' },
  { value: 'GitHub CI/CD', label: 'Automated delivery' },
];

const profilePoints = [
  'Rack-and-stack and server deployment experience',
  'Linux administration and troubleshooting background',
  'Self-hosted systems for development, backups, and web app hosting',
];
---

<BaseLayout
  title="Shane Kanterman | Infrastructure and Web Projects"
  description="Portfolio site for Shane Kanterman, a Computer Science student with hands-on Linux, server deployment, and cloud-hosted web project experience."
>
  <!-- Page shell -->
  <div
    class="relative z-10 w-[min(calc(100%-2rem),1240px)] mx-auto pb-20 max-[780px]:w-[min(calc(100%-2rem),1240px)]"
  >
    <!-- Header -->
    <header class="site-header sticky top-4 z-20 pt-4" id="header">
      <div
        class="header-inner glass flex items-center justify-between gap-4 px-5 py-4 rounded-full transition-[background-color,border-color,padding,box-shadow] duration-[180ms] ease-out"
      >
        <a
          class="inline-flex items-center gap-3.5 min-w-0"
          href="#top"
          aria-label="Shane Kanterman home"
        >
          <span
            class="inline-flex items-center justify-center w-11 h-11 rounded-full font-extrabold text-sm tracking-widest text-white flex-shrink-0"
            style="background:#1e293b;"
          >
            SK
          </span>
          <span class="flex flex-col min-w-0">
            <strong class="text-[0.95rem] leading-tight text-[#18181b]">Shane Kanterman</strong>
            <span class="text-[0.76rem] leading-tight text-[#71717a] max-[780px]:hidden">
              Infrastructure and Web Projects
            </span>
          </span>
        </a>

        <nav class="flex items-center gap-6 max-[780px]:hidden" aria-label="Primary">
          {['About', 'Projects', 'Skills', 'Contact'].map((item) => (
            <a
              href={`#${item.toLowerCase()}`}
              class="text-[#52525b] hover:text-[#18181b] transition-colors duration-[180ms] font-medium"
            >
              {item}
            </a>
          ))}
        </nav>

        <button
          class="mobile-toggle hidden max-[780px]:inline-grid place-items-center w-11 h-11 border border-[rgba(0,0,0,0.10)] bg-white rounded-full p-0 cursor-pointer"
          type="button"
          aria-expanded="false"
          aria-controls="mobile-nav"
        >
          <span class="block w-[1.1rem] h-[2px] my-[3px] mx-auto bg-[#18181b] rounded-full transition-transform duration-[180ms]"></span>
          <span class="block w-[1.1rem] h-[2px] my-[3px] mx-auto bg-[#18181b] rounded-full transition-[transform,opacity] duration-[180ms]"></span>
          <span class="block w-[1.1rem] h-[2px] my-[3px] mx-auto bg-[#18181b] rounded-full transition-transform duration-[180ms]"></span>
          <span class="sr-only">Toggle navigation</span>
        </button>
      </div>

      <nav
        class="mobile-nav glass mt-3.5 p-3 rounded-[var(--radius-md)]"
        id="mobile-nav"
        aria-label="Mobile navigation"
        hidden
      >
        {['About', 'Projects', 'Skills', 'Contact'].map((item) => (
          <a
            href={`#${item.toLowerCase()}`}
            class="block px-4 py-3.5 rounded-xl text-[#52525b] hover:text-[#18181b] hover:bg-[rgba(0,0,0,0.04)] transition-colors duration-[180ms]"
          >
            {item}
          </a>
        ))}
      </nav>
    </header>

    <main class="pt-8">
      <!-- Hero -->
      <section
        class="grid grid-cols-[minmax(0,1.15fr)_minmax(18rem,24rem)] gap-10 items-start min-h-[calc(100vh-8rem)] pt-6 pb-20 scroll-mt-[10.5rem] max-[960px]:grid-cols-1 max-[960px]:min-h-0 max-[960px]:pt-9 max-[960px]:pb-11"
        id="top"
      >
        <!-- Copy -->
        <div>
          <p class="mb-4 text-[#71717a] text-[0.82rem] font-bold tracking-[0.16em] uppercase">
            Computer Science Student
          </p>
          <h1
            class="text-[clamp(2.6rem,4.5vw,4.2rem)] leading-[1.06] tracking-[-0.02em] mb-5 max-w-[14ch] font-extrabold overflow-wrap-break-word text-[#18181b]"
          >
            Building <span class="gradient-text">reliable web systems</span> with a practical
            infrastructure background.
          </h1>
          <p class="text-[#52525b] leading-[1.75] text-[1.04rem] max-w-[48rem]">
            I build projects that connect frontend delivery with real hosting, deployment, and
            operational thinking. This portfolio is designed to show both the code and the systems
            mindset behind it.
          </p>

          <div class="flex flex-wrap gap-4 mt-8 max-[780px]:flex-col max-[780px]:items-stretch">
            <a class="btn btn-primary" href="#projects">
              View Projects
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M7 17L17 7" />
                <path d="M9 7h8v8" />
              </svg>
            </a>
            <a
              class="btn btn-secondary"
              href="https://www.linkedin.com/in/shane-kanterman-4511a2234"
              target="_blank"
              rel="noopener"
            >
              LinkedIn
            </a>
          </div>
        </div>

        <!-- Hero panel -->
        <GlassCard
          class="sticky top-28 flex flex-col gap-8 p-8 max-[960px]:static"
          hover={false}
        >
          <div>
            <p class="mb-4 text-[#71717a] text-[0.78rem] font-bold tracking-[0.14em] uppercase">
              Current focus
            </p>
            <ul class="grid gap-4 p-0 list-none">
              {heroFacts.map((fact) => (
                <li class="relative pl-5 text-[#52525b] leading-[1.6] text-[0.95rem]">
                  <span
                    class="absolute left-0 top-[0.72rem] -translate-y-1/2 w-1.5 h-1.5 rounded-full"
                    style="background:#1e293b;box-shadow:0 0 0 4px rgba(30,41,59,0.08);"
                    aria-hidden="true"
                  ></span>
                  {fact}
                </li>
              ))}
            </ul>
          </div>

          <div class="grid gap-2.5 pt-5 border-t border-[rgba(0,0,0,0.08)]">
            {heroMetrics.map((metric) => (
              <div class="flex justify-between items-baseline gap-4 overflow-wrap-break-word">
                <span class="text-[0.93rem] font-bold text-[#18181b] leading-snug shrink-0">
                  {metric.value}
                </span>
                <span class="text-[0.82rem] text-[#71717a] leading-snug text-right">
                  {metric.label}
                </span>
              </div>
            ))}
          </div>
        </GlassCard>
      </section>

      <!-- About -->
      <AnimatedSection
        class="observe-animate pt-28 pb-8 scroll-mt-[10.5rem] max-[960px]:pt-[5.25rem] max-[960px]:pb-6"
        id="about"
        delay={1}
      >
        <div class="max-w-[48rem] mb-12 max-[780px]:mb-9">
          <p class="mb-4 text-[#71717a] text-[0.82rem] font-bold tracking-[0.16em] uppercase">
            About
          </p>
          <h2
            class="text-[clamp(2rem,4.1vw,3rem)] leading-[1.08] tracking-[-0.02em] mb-5 font-extrabold text-[#18181b] max-[780px]:text-[clamp(1.9rem,8vw,2.6rem)]"
          >
            From data center work to software projects.
          </h2>
          <p class="text-[#52525b] leading-[1.75] text-[1.04rem]">
            My background is rooted in infrastructure, deployment, and systems work. I am growing
            that into software development by building projects that are designed, shipped, and run
            like real products.
          </p>
        </div>

        <div
          class="grid grid-cols-[minmax(0,1.5fr)_minmax(18rem,1fr)] gap-5 max-[960px]:grid-cols-1"
        >
          <GlassCard
            class="grid gap-5 p-8 overflow-wrap-break-word min-w-0 max-[780px]:p-6"
            hover={true}
          >
            <p class="text-[#52525b] leading-[1.75] text-[1.04rem]">
              I am a Computer Science student at Southern Connecticut State University with hands-on
              experience in rack-and-stack, server deployment, PXE boot imaging, Linux
              administration, and hardware troubleshooting.
            </p>
            <p class="text-[#52525b] leading-[1.75] text-[1.04rem]">
              I completed a data center internship at InterServer and continue building my skills
              through self-hosted systems for remote development, backups, and web app hosting.
            </p>
          </GlassCard>

          <GlassCard
            class="p-8 overflow-wrap-break-word min-w-0 max-[780px]:p-6"
            hover={true}
          >
            <p class="mb-4 text-[#71717a] text-[0.78rem] font-bold tracking-[0.14em] uppercase">
              What that looks like
            </p>
            <ul class="grid gap-4 p-0 list-none">
              {profilePoints.map((point) => (
                <li class="relative pl-5 text-[#52525b] leading-[1.6] text-[0.95rem]">
                  <span
                    class="absolute left-0 top-[0.72rem] -translate-y-1/2 w-1.5 h-1.5 rounded-full"
                    style="background:#1e293b;box-shadow:0 0 0 4px rgba(30,41,59,0.08);"
                    aria-hidden="true"
                  ></span>
                  {point}
                </li>
              ))}
            </ul>
          </GlassCard>
        </div>
      </AnimatedSection>

      <!-- Projects -->
      <AnimatedSection
        class="observe-animate pt-28 pb-8 scroll-mt-[10.5rem] max-[960px]:pt-[5.25rem] max-[960px]:pb-6"
        id="projects"
        delay={1}
      >
        <div class="max-w-[48rem] mb-11 max-[780px]:mb-9">
          <p class="mb-4 text-[#71717a] text-[0.82rem] font-bold tracking-[0.16em] uppercase">
            Projects
          </p>
          <h2
            class="text-[clamp(2rem,4.1vw,3rem)] leading-[1.08] tracking-[-0.02em] mb-5 font-extrabold text-[#18181b] max-[780px]:text-[clamp(1.9rem,8vw,2.6rem)]"
          >
            Work that shows how I build and deploy.
          </h2>
          <p class="text-[#52525b] leading-[1.75] text-[1.04rem]">
            The strongest projects here are the ones that combine implementation with hosting,
            automation, and operational discipline.
          </p>
        </div>

        <div class="grid gap-5">
          <!-- Featured project -->
          <GlassCard
            class="p-8 overflow-wrap-break-word min-w-0 max-[780px]:p-6"
            hover={true}
          >
            <div class="flex flex-wrap items-start justify-between gap-3 mb-4">
              <p class="text-[#71717a] text-[0.78rem] font-bold tracking-[0.14em] uppercase">
                Featured project
              </p>
              <div class="flex flex-wrap gap-2">
                {featuredProject.data.stack.map((item) => (
                  <span
                    class="inline-flex items-center min-h-8 px-3 py-1.5 rounded-full border border-[rgba(0,0,0,0.10)] bg-[rgba(0,0,0,0.04)] text-[#1e293b] text-[0.8rem] font-medium"
                  >
                    {item}
                  </span>
                ))}
              </div>
            </div>
              <h3 class="text-[1.28rem] leading-[1.25] tracking-[-0.01em] font-bold mb-3 text-[#18181b]">
                {featuredProject.data.title}
              </h3>
              <p class="text-[#52525b] leading-[1.75] text-[1.04rem]">
                {featuredProject.data.summary}
              </p>
              <div class="mt-6">
                <a
                  href={`/projects/${featuredProject.id}`}
                  class="inline-flex items-center gap-2 text-[#1e293b] hover:text-[#0f172a] transition-colors duration-[180ms] font-medium"
                >
                  Read case study
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M7 17L17 7" />
                    <path d="M9 7h8v8" />
                  </svg>
                </a>
              </div>
            </GlassCard>

          <!-- Supporting projects -->
          <div class="grid grid-cols-2 gap-5 max-[960px]:grid-cols-1">
            {supportingProjects.map((project) => (
              <GlassCard
                class="p-8 overflow-wrap-break-word min-w-0 max-[780px]:p-6"
                hover={true}
              >
                <div class="flex flex-wrap gap-2 mb-4">
                  {project.data.stack.map((item) => (
                    <span
                      class="inline-flex items-center min-h-8 px-3 py-1.5 rounded-full border border-[rgba(0,0,0,0.10)] bg-[rgba(0,0,0,0.04)] text-[#1e293b] text-[0.8rem] font-medium"
                    >
                      {item}
                    </span>
                  ))}
                </div>
                <h3 class="text-[1.28rem] leading-[1.25] tracking-[-0.01em] font-bold mb-3 text-[#18181b]">
                  {project.data.title}
                </h3>
                <p class="text-[#52525b] leading-[1.75] text-[1.04rem]">{project.data.summary}</p>
                <div class="mt-6">
                  <a
                    href={`/projects/${project.id}`}
                    class="inline-flex items-center gap-2 text-[#1e293b] hover:text-[#0f172a] transition-colors duration-[180ms] font-medium"
                  >
                    Read case study
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                      <path d="M7 17L17 7" />
                      <path d="M9 7h8v8" />
                    </svg>
                  </a>
                </div>
              </GlassCard>
            ))}
          </div>
        </div>
      </AnimatedSection>

      <!-- Skills -->
      <AnimatedSection
        class="observe-animate pt-28 pb-8 scroll-mt-[10.5rem] max-[960px]:pt-[5.25rem] max-[960px]:pb-6"
        id="skills"
        delay={1}
      >
        <div class="max-w-[48rem] mb-12 max-[780px]:mb-9">
          <p class="mb-4 text-[#71717a] text-[0.82rem] font-bold tracking-[0.16em] uppercase">
            Skills
          </p>
          <h2
            class="text-[clamp(2rem,4.1vw,3rem)] leading-[1.08] tracking-[-0.02em] mb-5 font-extrabold text-[#18181b] max-[780px]:text-[clamp(1.9rem,8vw,2.6rem)]"
          >
            Current tools and areas of focus.
          </h2>
          <p class="text-[#52525b] leading-[1.75] text-[1.04rem]">
            The goal is not just to know tools, but to use them together to ship dependable work.
          </p>
        </div>

        <div class="grid grid-cols-3 gap-5 max-[960px]:grid-cols-2 max-[580px]:grid-cols-1">
          {capabilityGroups.map((group) => (
            <GlassCard
              class="grid content-start gap-4 p-8 min-h-full overflow-wrap-break-word min-w-0 max-[780px]:p-6"
              hover={true}
            >
              <p class="text-[#71717a] text-[0.78rem] font-bold tracking-[0.14em] uppercase">
                {group.name}
              </p>
              <p class="text-[#52525b] leading-[1.75] text-[1.04rem]">{group.description}</p>
              <div class="flex flex-wrap gap-2">
                {group.items.map((item) => (
                  <span
                    class="inline-flex items-center min-h-8 px-3 py-1.5 rounded-full border border-[rgba(0,0,0,0.10)] bg-[rgba(0,0,0,0.04)] text-[#1e293b] text-[0.8rem] font-medium"
                  >
                    {item}
                  </span>
                ))}
              </div>
            </GlassCard>
          ))}
        </div>
      </AnimatedSection>

      <!-- Contact -->
      <AnimatedSection
        class="observe-animate pt-28 pb-8 scroll-mt-[10.5rem] max-[960px]:pt-[5.25rem] max-[960px]:pb-6"
        id="contact"
        delay={1}
      >
        <GlassCard
          class="grid grid-cols-[minmax(0,1.4fr)_auto] gap-10 items-center p-8 overflow-wrap-break-word min-w-0 max-[960px]:grid-cols-1 max-[780px]:p-6"
          hover={false}
        >
          <div class="max-w-[38rem]">
            <p class="mb-4 text-[#71717a] text-[0.82rem] font-bold tracking-[0.16em] uppercase">
              Contact
            </p>
            <h2
              class="text-[clamp(2rem,4.1vw,3rem)] leading-[1.08] tracking-[-0.02em] mb-5 font-extrabold text-[#18181b] max-[780px]:text-[clamp(1.9rem,8vw,2.6rem)]"
            >
              Open to technical opportunities and connections.
            </h2>
            <p class="text-[#52525b] leading-[1.75] text-[1.04rem]">
              I am currently open to part-time, contract, and junior roles related to
              infrastructure, deployment, and software development.
            </p>
          </div>

          <div class="max-[780px]:w-full">
            <a
              class="btn btn-primary max-[780px]:w-full"
              href="https://www.linkedin.com/in/shane-kanterman-4511a2234"
              target="_blank"
              rel="noopener"
            >
              Connect on LinkedIn
            </a>
          </div>
        </GlassCard>
      </AnimatedSection>

      <!-- Footer -->
      <footer class="pt-18 pb-0 text-center text-[#a1a1aa] text-[0.88rem]">
        <p>© {new Date().getFullYear()} Shane Kanterman. Built with Astro and deployed on GCP.</p>
      </footer>
    </main>
  </div>

  <script>
    const header = document.getElementById('header') as HTMLElement | null;
    const mobileToggle = document.querySelector<HTMLButtonElement>('.mobile-toggle');
    const mobileNav = document.getElementById('mobile-nav') as HTMLElement | null;

    const syncHeader = (): void => {
      if (!header) return;
      header.classList.toggle('is-scrolled', window.scrollY > 12);
    };

    syncHeader();
    window.addEventListener('scroll', syncHeader, { passive: true });

    if (mobileToggle && mobileNav) {
      mobileToggle.addEventListener('click', () => {
        const expanded = mobileToggle.getAttribute('aria-expanded') === 'true';
        mobileToggle.setAttribute('aria-expanded', String(!expanded));
        mobileNav.hidden = expanded;

        // Animate hamburger → X
        const spans = mobileToggle.querySelectorAll<HTMLSpanElement>('span:not(.sr-only)');
        if (!expanded) {
          spans[0]?.style.setProperty('transform', 'translateY(8px) rotate(45deg)');
          spans[1]?.style.setProperty('opacity', '0');
          spans[2]?.style.setProperty('transform', 'translateY(-8px) rotate(-45deg)');
        } else {
          spans[0]?.style.removeProperty('transform');
          spans[1]?.style.removeProperty('opacity');
          spans[2]?.style.removeProperty('transform');
        }
      });

      mobileNav.querySelectorAll('a').forEach((link) => {
        link.addEventListener('click', () => {
          mobileToggle.setAttribute('aria-expanded', 'false');
          mobileNav.hidden = true;
          const spans = mobileToggle.querySelectorAll<HTMLSpanElement>('span:not(.sr-only)');
          spans[0]?.style.removeProperty('transform');
          spans[1]?.style.removeProperty('opacity');
          spans[2]?.style.removeProperty('transform');
        });
      });
    }
  </script>
</BaseLayout>
