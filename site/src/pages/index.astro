---
import AnimatedSection from '../components/AnimatedSection.astro';
import ArchitectureSnapshot from '../components/ArchitectureSnapshot.astro';
import BaseLayout from '../layouts/BaseLayout.astro';
import GlassCard from '../components/GlassCard.astro';
import ProjectCard from '../components/ProjectCard.astro';
import SectionIntro from '../components/SectionIntro.astro';
import SiteHeader from '../components/SiteHeader.astro';
import StackBadge from '../components/StackBadge.astro';
import { getCollection } from 'astro:content';

const allProjects = await getCollection('projects');
const sorted = allProjects.sort((a, b) => a.data.order - b.data.order);
const featuredProject = sorted.find((project) => project.data.featured)!;
const supportingProjects = sorted.filter((project) => !project.data.featured);

const navItems = [
  { label: 'About', href: '#about' },
  { label: 'Architecture', href: '#architecture' },
  { label: 'Projects', href: '#projects' },
  { label: 'Skills', href: '#skills' },
  { label: 'Contact', href: '#contact' },
];

const proofStats = [
  { value: 'Datacenter Technician', label: 'Rack-and-stack, PXE imaging, OS installs at InterServer' },
  { value: 'PXE deployment', label: 'Network boot imaging and server provisioning' },
  { value: '2 origin VMs', label: 'Multi-zone deployment on GCP with failover' },
  { value: '~$12-16/mo', label: 'Cost-conscious cloud infrastructure footprint' },
];

const capabilityGroups = [
  {
    name: 'Deploy and Operate',
    description: 'Provision Linux systems, serve applications, and keep deployments understandable and reliable.',
    items: ['Linux', 'Nginx', 'Google Cloud', 'Terraform', 'Proxmox', 'PXE Boot'],
  },
  {
    name: 'Build and Ship',
    description: 'Frontend and scripting work tied directly to deployment, automation, and maintainable delivery.',
    items: ['Astro', 'HTML', 'CSS', 'JavaScript', 'Python', 'Git'],
  },
  {
    name: 'Troubleshoot and Maintain',
    description: 'Operational habits shaped by real systems work, from hardware issues to deployment workflows.',
    items: ['GitHub Actions', 'SSH', 'Virtualization', 'Windows', 'Containers'],
  },
];

const systemSummary = [
  { label: 'Edge', value: 'Cloudflare handles DNS, CDN, TLS, and balancing.' },
  { label: 'Origins', value: 'Two GCP VMs run Nginx in separate availability zones.' },
  { label: 'Application', value: 'Astro ships as a static build with low operational overhead.' },
  { label: 'Delivery', value: 'GitHub Actions builds and deploys to both servers on every push.' },
];

const heroMetrics = [
  { value: '2 zones', label: 'Redundant origins' },
  { value: '60s interval', label: 'Cloudflare health checks' },
  { value: 'Static Astro', label: 'Low-complexity app layer' },
];

const profilePoints = [
  'Rack-and-stack and server deployment experience',
  'Linux administration and troubleshooting background',
  'Self-hosted systems for development, backups, and web app hosting',
];

const experienceCards = [
  {
    eyebrow: 'InterServer — Secaucus, NJ',
    title: 'Data Center Technician',
    body:
      'Live data center work: rack-and-stack, OS installs (Linux, Windows, Proxmox), PXE imaging, hardware diagnostics, and deployment documentation.',
    period: 'June 2025 – Present',
  },
  {
    eyebrow: 'Southern Connecticut State University',
    title: 'Computer Science Student',
    body:
      'Building skills in software engineering, operating systems, and networking. Active member of the university football program.',
    period: 'Sept. 2023 – May 2027',
  },
  {
    eyebrow: 'How I work',
    title: 'Infrastructure-first mindset',
    body:
      'I prefer simple, reliable systems with clear deployment paths. I care about how software fails, how it is maintained, and how its infrastructure can stay lean without sacrificing reliability.',
    period: '',
  },
];

const certifications = [
  {
    name: 'Technical Support Fundamentals',
    issuer: 'Google / Coursera',
    date: 'June 2025',
    credentialId: '5BHVX4W2WMD5',
  },
];

const githubUrl = 'https://github.com/ShaneKanterman04';
const linkedInUrl = 'https://www.linkedin.com/in/shane-kanterman-4511a2234';
const emailUrl = 'mailto:shanekanterman04@gmail.com';
const resumeUrl = '/Kanterman_Resume.pdf';

const siteUrl = Astro.site?.toString() ?? 'https://shanekanterman.dev';

const structuredData = [
  {
    '@context': 'https://schema.org',
    '@type': 'WebSite',
    name: 'Shane Kanterman',
    url: siteUrl,
      description:
        'Portfolio site for Shane Kanterman featuring Linux infrastructure, cloud deployment, and web projects with hands-on operations experience.',
  },
  {
    '@context': 'https://schema.org',
    '@type': 'Person',
    name: 'Shane Kanterman',
    url: siteUrl,
    sameAs: [linkedInUrl, githubUrl],
    email: 'mailto:shanekanterman04@gmail.com',
    alumniOf: {
      '@type': 'CollegeOrUniversity',
      name: 'Southern Connecticut State University',
    },
    knowsAbout: [
      'Linux administration',
      'Cloud deployment',
      'Server deployment',
      'Data center operations',
      'Infrastructure',
      'Web development',
      'Terraform',
      'Nginx',
    ],
    jobTitle: 'Computer Science Student',
  },
];
---

<BaseLayout
  title="Shane Kanterman | Linux Infrastructure and Web Projects"
  description="Portfolio site for Shane Kanterman featuring Linux infrastructure, cloud deployment, and web projects shaped by hands-on operations experience."
  image="/og/portfolio-preview.png"
  imageAlt="Shane Kanterman portfolio preview"
  structuredData={structuredData}
>
  <div
    class="relative z-10 w-[min(calc(100%-2rem),1240px)] mx-auto pb-20 max-[780px]:w-[min(calc(100%-2rem),1240px)]"
  >
    <SiteHeader home={true} navItems={navItems} />

    <main class="pt-8" id="main-content">
      <section
        class="hero-surface grid grid-cols-[minmax(0,1.15fr)_minmax(18rem,24rem)] gap-10 items-start min-h-[calc(100vh-8rem)] pt-6 pb-20 scroll-mt-[10.5rem] max-[960px]:grid-cols-1 max-[960px]:min-h-0 max-[960px]:pt-7 max-[960px]:pb-8 max-[780px]:pt-5 max-[780px]:pb-6"
        id="top"
      >
        <div>
          <p class="mb-4 text-[#71717a] text-[0.82rem] font-bold tracking-[0.16em] uppercase">
            Computer Science Student + Data Center Technician
          </p>
          <h1
            class="text-[clamp(2.6rem,4.5vw,4.2rem)] leading-[1.06] tracking-[-0.02em] mb-5 max-w-[14ch] font-extrabold overflow-wrap-break-word text-[#18181b]"
          >
            Building <span class="gradient-text">Linux infrastructure
            and web projects</span> that are designed to ship.
          </h1>
          <p class="text-[#52525b] leading-[1.75] text-[1.04rem] max-w-[48rem]">
            Computer Science student with hands-on data center operations experience in server
            deployment, PXE imaging, Linux administration, and cloud infrastructure. Based
            between Cranford, NJ and New Haven, CT.
          </p>

          <div class="flex flex-wrap gap-4 mt-8 max-[780px]:flex-col max-[780px]:items-stretch">
            <a class="btn btn-primary" href="#projects">
              View Case Studies
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M7 17L17 7" />
                <path d="M9 7h8v8" />
              </svg>
            </a>
            <a
              class="btn btn-secondary"
              href={resumeUrl}
              target="_blank"
              rel="noopener noreferrer"
            >
              Resume
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4" />
                <polyline points="7 10 12 15 17 10" />
                <line x1="12" y1="15" x2="12" y2="3" />
              </svg>
            </a>
            <a
              class="btn btn-secondary"
              href={linkedInUrl}
              target="_blank"
              rel="noopener noreferrer"
            >
              LinkedIn
            </a>
            <a
              class="btn btn-secondary"
              href={githubUrl}
              target="_blank"
              rel="noopener noreferrer"
            >
              GitHub
            </a>
          </div>

          <div class="proof-strip mt-6 max-[780px]:mt-5" aria-label="Portfolio proof points">
            {proofStats.map((stat) => (
              <div class="proof-stat">
                <strong>{stat.value}</strong>
                <span>{stat.label}</span>
              </div>
            ))}
          </div>
        </div>

        <GlassCard class="sticky top-28 flex flex-col gap-8 p-8 max-[960px]:static" hover={false}>
          <div>
            <p class="mb-4 text-[#71717a] text-[0.78rem] font-bold tracking-[0.14em] uppercase">
              How this site runs
            </p>
            <ul class="grid gap-4 p-0 list-none">
              {systemSummary.map((item) => (
                <li class="system-summary-row">
                  <span class="system-summary-label">{item.label}</span>
                  <span class="system-summary-copy">{item.value}</span>
                </li>
              ))}
            </ul>
          </div>

          <div class="grid gap-2.5 pt-5 border-t border-[rgba(0,0,0,0.08)]">
            {heroMetrics.map((metric) => (
              <div class="flex justify-between items-baseline gap-4 overflow-wrap-break-word">
                <span class="text-[0.93rem] font-bold text-[#18181b] leading-snug shrink-0">
                  {metric.value}
                </span>
                <span class="text-[0.82rem] text-[#71717a] leading-snug text-right">
                  {metric.label}
                </span>
              </div>
            ))}
          </div>
        </GlassCard>
      </section>

      <AnimatedSection
        class="observe-animate pt-28 pb-8 scroll-mt-[10.5rem] max-[960px]:pt-[5.25rem] max-[960px]:pb-6 max-[780px]:pt-14 max-[780px]:pb-4"
        id="about"
        delay={1}
      >
        <SectionIntro
          eyebrow="About"
          title="From data center operations to software delivery."
          body="I started with physical infrastructure work and carried those habits into software: keep systems simple, deploy them cleanly, and make them maintainable."
        />

        <div
          class="grid grid-cols-[minmax(0,1.5fr)_minmax(18rem,1fr)] gap-5 max-[960px]:grid-cols-1"
        >
          <GlassCard class="grid gap-5 p-8 overflow-wrap-break-word min-w-0 max-[780px]:p-6" hover={true}>
            <p class="text-[#52525b] leading-[1.75] text-[1.04rem]">
              CS student at SCSU and Data Center Technician at InterServer. Experience in
              rack-and-stack, PXE boot imaging, Linux administration, and hardware troubleshooting
              in a live production environment.
            </p>
            <p class="text-[#52525b] leading-[1.75] text-[1.04rem]">
              That background changed how I evaluate software work: not only what gets built, but
              how it is deployed, operated, and kept reliable over time.
            </p>
          </GlassCard>

          <GlassCard class="p-8 overflow-wrap-break-word min-w-0 max-[780px]:p-6" hover={true}>
            <p class="mb-4 text-[#71717a] text-[0.78rem] font-bold tracking-[0.14em] uppercase">
              Where I am headed
            </p>
            <p class="text-[#52525b] leading-[1.75] text-[1.04rem] mb-3">
              Looking for junior software, infrastructure, and platform roles where application
              work overlaps with Linux, deployment, and operational ownership.
            </p>
            <p class="text-[#52525b] leading-[1.6] text-[0.96rem]">
              Cranford, NJ and New Haven, CT. Open to internship and full-time.
            </p>
          </GlassCard>
        </div>

        <div class="grid grid-cols-3 gap-5 mt-5 max-[960px]:grid-cols-1">
          {experienceCards.map((card) => (
            <GlassCard class="grid content-start gap-3 p-7 min-w-0 max-[780px]:p-6" hover={true}>
              <div>
                <p class="text-[#71717a] text-[0.78rem] font-bold tracking-[0.14em] uppercase">
                  {card.eyebrow}
                </p>
                {card.period && (
                  <p class="text-[#a1a1aa] text-[0.76rem] mt-0.5">{card.period}</p>
                )}
              </div>
              <h3 class="text-[1.12rem] leading-[1.3] font-bold text-[#18181b] m-0">{card.title}</h3>
              <p class="text-[#52525b] leading-[1.7] text-[0.95rem] m-0">{card.body}</p>
            </GlassCard>
          ))}
        </div>

        <div class="grid grid-cols-[auto_1fr] gap-5 mt-5 items-start max-[580px]:grid-cols-1">
          <GlassCard class="grid content-start gap-3 p-7 min-w-0 max-[780px]:p-6" hover={true}>
            <p class="text-[#71717a] text-[0.78rem] font-bold tracking-[0.14em] uppercase">
              Certifications
            </p>
            <div class="grid gap-3">
              {certifications.map((cert) => (
                <div class="certification-row">
                  <strong class="text-[0.97rem] text-[#18181b]">{cert.name}</strong>
                  <span class="text-[#52525b] text-[0.9rem]">{cert.issuer} &middot; {cert.date}</span>
                </div>
              ))}
            </div>
          </GlassCard>

          <GlassCard class="grid gap-3 p-7 min-w-0 max-[780px]:p-6" hover={true}>
            <p class="text-[#71717a] text-[0.78rem] font-bold tracking-[0.14em] uppercase">
              What that looks like in practice
            </p>
            <ul class="grid gap-3 p-0 list-none">
              {profilePoints.map((point) => (
                <li class="relative pl-5 text-[#52525b] leading-[1.6] text-[0.95rem]">
                  <span
                    class="profile-point-dot absolute left-0 top-[0.72rem] -translate-y-1/2 w-1.5 h-1.5 rounded-full"
                    aria-hidden="true"
                  ></span>
                  {point}
                </li>
              ))}
            </ul>
          </GlassCard>
        </div>
      </AnimatedSection>

      <AnimatedSection
        class="observe-animate pt-28 pb-8 scroll-mt-[10.5rem] max-[960px]:pt-[5.25rem] max-[960px]:pb-6 max-[780px]:pt-14 max-[780px]:pb-4"
        id="architecture"
        delay={1}
      >
        <SectionIntro
          eyebrow="Architecture"
          title="A portfolio site backed by real deployment decisions."
          body="The application layer is intentionally simple. The interesting work is in the deployment model: edge routing, redundant origins, automated delivery, and a low-cost footprint."
        />

        <div class="grid grid-cols-[minmax(0,1fr)_minmax(18rem,30rem)] gap-5 items-start max-[960px]:grid-cols-1">
          <GlassCard class="grid gap-5 p-8 overflow-wrap-break-word min-w-0 max-[780px]:p-6" hover={true}>
            <div>
              <p class="mb-3 text-[#71717a] text-[0.78rem] font-bold tracking-[0.14em] uppercase">
                Why it stands out
              </p>
              <p class="text-[#52525b] leading-[1.75] text-[1.04rem] m-0">
                Instead of stopping at a static frontend, this site is deployed across two origin
                VMs with health-checked failover and automated delivery.
              </p>
            </div>

            <div class="grid gap-3">
              <div class="proof-inline-row">
                <span class="project-proof-label">Edge services</span>
                <span class="project-proof-copy">Cloudflare provides DNS, CDN, TLS, and balancing.</span>
              </div>
              <div class="proof-inline-row">
                <span class="project-proof-label">Origins</span>
                <span class="project-proof-copy">Two GCP VMs in separate zones reduce single-instance risk.</span>
              </div>
              <div class="proof-inline-row">
                <span class="project-proof-label">Delivery</span>
                <span class="project-proof-copy">GitHub Actions pushes each build to both servers.</span>
              </div>
            </div>
          </GlassCard>

          <GlassCard class="p-8 max-[780px]:p-6" hover={false}>
            <ArchitectureSnapshot />
          </GlassCard>
        </div>
      </AnimatedSection>

      <AnimatedSection
        class="observe-animate pt-28 pb-8 scroll-mt-[10.5rem] max-[960px]:pt-[5.25rem] max-[960px]:pb-6 max-[780px]:pt-14 max-[780px]:pb-4"
        id="projects"
        delay={1}
      >
        <SectionIntro
          eyebrow="Projects"
          title="Projects that connect software work to operations and deployment."
          body="Each case study focuses on the decisions, constraints, and responsibilities behind the work, not just the finished interface."
          class="mb-11"
        />

        <div class="grid gap-5">
          <ProjectCard project={featuredProject} featured={true} />

          <div class="grid grid-cols-2 gap-5 max-[960px]:grid-cols-1">
            {supportingProjects.map((project) => (
              <ProjectCard project={project} />
            ))}
          </div>
        </div>
      </AnimatedSection>

      <AnimatedSection
        class="observe-animate pt-28 pb-8 scroll-mt-[10.5rem] max-[960px]:pt-[5.25rem] max-[960px]:pb-6 max-[780px]:pt-14 max-[780px]:pb-4"
        id="skills"
        delay={1}
      >
        <SectionIntro
          eyebrow="Skills"
          title="Skills used to build, deploy, and maintain systems."
          body="These are the tools and workflows I use across application work, Linux administration, deployment, and troubleshooting."
        />

        <div class="grid grid-cols-3 gap-5 max-[960px]:grid-cols-2 max-[580px]:grid-cols-1">
          {capabilityGroups.map((group) => (
            <GlassCard
              class="grid content-start gap-4 p-8 min-h-full overflow-wrap-break-word min-w-0 max-[780px]:p-6"
              hover={true}
            >
              <p class="text-[#71717a] text-[0.78rem] font-bold tracking-[0.14em] uppercase">
                {group.name}
              </p>
              <p class="text-[#52525b] leading-[1.75] text-[1.04rem]">{group.description}</p>
              <div class="flex flex-wrap gap-2">
                {group.items.map((item) => (
                  <StackBadge label={item} />
                ))}
              </div>
            </GlassCard>
          ))}
        </div>
      </AnimatedSection>

      <AnimatedSection
        class="observe-animate pt-28 pb-8 scroll-mt-[10.5rem] max-[960px]:pt-[5.25rem] max-[960px]:pb-6 max-[780px]:pt-14 max-[780px]:pb-4"
        id="contact"
        delay={1}
      >
        <GlassCard
          class="grid grid-cols-[minmax(0,1.4fr)_auto] gap-10 items-center p-8 overflow-wrap-break-word min-w-0 max-[960px]:grid-cols-1 max-[780px]:p-6"
          hover={false}
        >
          <div class="max-w-[38rem]">
            <p class="mb-4 text-[#71717a] text-[0.82rem] font-bold tracking-[0.16em] uppercase">
              Open to roles
            </p>
            <h2
              class="text-[clamp(2rem,4.1vw,3rem)] leading-[1.08] tracking-[-0.02em] mb-5 font-extrabold text-[#18181b] max-[780px]:text-[clamp(1.9rem,8vw,2.6rem)]"
            >
              Looking for early-career software, infrastructure, and platform opportunities.
            </h2>
            <p class="text-[#52525b] leading-[1.75] text-[1.04rem] mb-3">
              Most interested in roles where software delivery overlaps with Linux, deployment,
              and systems ownership. Open to internship and full-time opportunities.
            </p>
            <p class="text-[#71717a] text-[0.88rem]">shanekanterman04@gmail.com &middot; Cranford, NJ / New Haven, CT</p>
          </div>

          <div class="contact-link-grid max-[780px]:w-full">
            <a
              class="btn btn-primary max-[780px]:w-full"
              href={resumeUrl}
              target="_blank"
              rel="noopener noreferrer"
            >
              Resume
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4" />
                <polyline points="7 10 12 15 17 10" />
                <line x1="12" y1="15" x2="12" y2="3" />
              </svg>
            </a>
            <a
              class="btn btn-secondary max-[780px]:w-full"
              href={emailUrl}
            >
              Email me
            </a>
            <a
              class="btn btn-secondary max-[780px]:w-full"
              href={linkedInUrl}
              target="_blank"
              rel="noopener noreferrer"
            >
              LinkedIn
            </a>
            <a
              class="btn btn-secondary max-[780px]:w-full"
              href={githubUrl}
              target="_blank"
              rel="noopener noreferrer"
            >
              GitHub
            </a>
          </div>
        </GlassCard>
      </AnimatedSection>

    </main>
  </div>

  <script>
    const header = document.getElementById('header');
    const mobileToggle = document.querySelector('.mobile-toggle');
    const mobileNav = document.getElementById('mobile-nav');
    const sectionIds = ['about', 'architecture', 'projects', 'skills', 'contact'];
    const sectionLinks = Array.from(document.querySelectorAll('[data-nav-link]'));
    const mobileBreakpoint = window.matchMedia('(min-width: 781px)');

    let scrollFrame = 0;

    const syncHeader = () => {
      if (!header) return;
      header.classList.toggle('is-scrolled', window.scrollY > 12);
      scrollFrame = 0;
    };

    const requestHeaderSync = () => {
      if (scrollFrame !== 0) return;
      scrollFrame = window.requestAnimationFrame(syncHeader);
    };

    syncHeader();
    window.addEventListener('scroll', requestHeaderSync, { passive: true });

    const setActiveSection = (sectionId) => {
      sectionLinks.forEach((link) => {
        const isActive = link.getAttribute('data-nav-link') === sectionId;
        if (isActive) {
          link.setAttribute('aria-current', 'location');
        } else {
          link.removeAttribute('aria-current');
        }
      });
    };

    if ('IntersectionObserver' in window) {
      const observer = new IntersectionObserver(
        (entries) => {
          const visibleEntries = entries
            .filter((entry) => entry.isIntersecting)
            .sort((a, b) => b.intersectionRatio - a.intersectionRatio);

          if (visibleEntries.length > 0) {
            setActiveSection(visibleEntries[0].target.id);
          }
        },
        {
          rootMargin: '-35% 0px -45% 0px',
          threshold: [0.2, 0.4, 0.6],
        },
      );

      sectionIds.forEach((id) => {
        const section = document.getElementById(id);
        if (section) observer.observe(section);
      });
    }

    if (mobileToggle instanceof HTMLButtonElement && mobileNav instanceof HTMLElement) {
      const iconBars = mobileToggle.querySelectorAll('span:not(.sr-only)');

      const renderMenuState = (open) => {
        mobileToggle.setAttribute('aria-expanded', String(open));
        mobileNav.classList.toggle('is-open', open);

        if (open) {
          iconBars[0]?.style.setProperty('transform', 'translateY(8px) rotate(45deg)');
          iconBars[1]?.style.setProperty('opacity', '0');
          iconBars[2]?.style.setProperty('transform', 'translateY(-8px) rotate(-45deg)');
        } else {
          iconBars[0]?.style.removeProperty('transform');
          iconBars[1]?.style.removeProperty('opacity');
          iconBars[2]?.style.removeProperty('transform');
        }
      };

      const closeMenu = (restoreFocus = true) => {
        renderMenuState(false);
        if (restoreFocus) mobileToggle.focus();
      };

      renderMenuState(false);

      mobileToggle.addEventListener('click', () => {
        const shouldOpen = mobileToggle.getAttribute('aria-expanded') !== 'true';
        renderMenuState(shouldOpen);

        if (shouldOpen) {
          const firstLink = mobileNav.querySelector('a');
          firstLink?.focus();
        }
      });

      mobileNav.querySelectorAll('a').forEach((link) => {
        link.addEventListener('click', () => {
          closeMenu(false);
        });
      });

      document.addEventListener('keydown', (event) => {
        if (event.key === 'Escape' && mobileToggle.getAttribute('aria-expanded') === 'true') {
          closeMenu();
        }
      });

      mobileBreakpoint.addEventListener('change', (event) => {
        if (event.matches) {
          closeMenu(false);
        }
      });
    }
  </script>
</BaseLayout>
