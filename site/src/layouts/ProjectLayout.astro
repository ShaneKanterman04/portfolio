---
import BaseLayout from './BaseLayout.astro';
import type { CollectionEntry } from 'astro:content';

interface Props {
  project: CollectionEntry<'projects'>;
}

const { project } = Astro.props;
const { title, summary, stack, status, date, links } = project.data;

const formatted = new Intl.DateTimeFormat('en-US', {
  year: 'numeric',
  month: 'long',
}).format(date);

const statusLabel: Record<string, string> = {
  shipped: 'Shipped',
  'in-progress': 'In Progress',
  archived: 'Archived',
};

const statusColor: Record<string, string> = {
  shipped: '#86efac',
  'in-progress': '#fcd34d',
  archived: '#6e7f99',
};

// Reading time from word count
const wordCount = project.body?.split(/\s+/).filter(Boolean).length ?? 0;
const readingTime = Math.max(1, Math.ceil(wordCount / 200));

// Extract h2 headings from the MDX body for the ToC
// Matches: ## Heading Text  (with optional trailing whitespace)
const headingMatches = project.body?.matchAll(/^##\s+(.+)$/gm) ?? [];
const tocItems: { text: string; slug: string }[] = [];
for (const match of headingMatches) {
  const text = match[1].trim();
  // Match the slug that rehype-slug generates
  const slug = text
    .toLowerCase()
    .replace(/[^\w\s-]/g, '')
    .replace(/\s+/g, '-')
    .replace(/-+/g, '-')
    .replace(/^-|-$/g, '');
  tocItems.push({ text, slug });
}
---

<BaseLayout title={`${title} | Shane Kanterman`} description={summary}>
  <!-- Progress bar -->
  <div
    id="progress-bar"
    class="fixed top-0 left-0 h-[2px] z-50 w-0 transition-none"
    style="background:var(--accent-gradient);"
    aria-hidden="true"
  ></div>

  <!-- Backdrop -->
  <div class="fixed inset-0 pointer-events-none z-0" aria-hidden="true">
    <div
      class="absolute w-[34rem] h-[34rem] rounded-full blur-[120px] opacity-15"
      style="top:-10rem;left:-8rem;background:#7a8fa8;"
    ></div>
    <div
      class="absolute w-[34rem] h-[34rem] rounded-full blur-[120px] opacity-15"
      style="top:20rem;right:-10rem;background:#8da4b8;"
    ></div>
    <div
      class="absolute inset-0"
      style="background-image:linear-gradient(rgba(255,255,255,0.018) 1px,transparent 1px),linear-gradient(90deg,rgba(255,255,255,0.018) 1px,transparent 1px);background-size:54px 54px;mask-image:radial-gradient(circle at top,black 28%,transparent 82%);"
    ></div>
  </div>

  <div class="relative z-10 w-[min(calc(100%-2rem),1240px)] mx-auto pb-24">

    <!-- Header -->
    <header class="sticky top-4 z-20 pt-4">
      <div class="glass flex items-center justify-between gap-4 px-5 py-4 rounded-full">
        <a class="inline-flex items-center gap-3.5 min-w-0" href="/" aria-label="Shane Kanterman home">
          <span
            class="inline-flex items-center justify-center w-11 h-11 rounded-full font-extrabold text-sm tracking-widest text-[#04101d] flex-shrink-0"
            style="background:var(--accent-gradient);"
          >SK</span>
          <span class="flex flex-col min-w-0">
            <strong class="text-[0.95rem] leading-tight">Shane Kanterman</strong>
            <span class="text-[0.76rem] leading-tight text-[#6e7f99] max-[600px]:hidden">
              Infrastructure and Web Projects
            </span>
          </span>
        </a>
        <a
          href="/#projects"
          class="inline-flex items-center gap-2 text-[#a0afc4] hover:text-[#f1f4f9] transition-colors duration-[180ms] text-sm font-medium"
        >
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M19 12H5M12 5l-7 7 7 7"/>
          </svg>
          All projects
        </a>
      </div>
    </header>

    <main class="pt-14">

      <!-- Article header (full width) -->
      <div class="max-w-[860px] mx-auto mb-12">
        <!-- Meta row -->
        <div class="flex flex-wrap items-center gap-x-4 gap-y-2 mb-7">
          <span class="text-[#94a3b8] text-[0.78rem] font-bold tracking-[0.16em] uppercase">
            Case Study
          </span>
          <span class="w-px h-3.5 bg-[rgba(148,163,184,0.25)]" aria-hidden="true"></span>
          <span class="text-[#6e7f99] text-[0.82rem]">{formatted}</span>
          <span class="w-px h-3.5 bg-[rgba(148,163,184,0.25)]" aria-hidden="true"></span>
          <span
            class="inline-flex items-center gap-1.5 text-[0.8rem] font-medium"
            style={`color:${statusColor[status]};`}
          >
            <span
              class="w-1.5 h-1.5 rounded-full flex-shrink-0"
              style={`background:${statusColor[status]};`}
            ></span>
            {statusLabel[status]}
          </span>
          <span class="w-px h-3.5 bg-[rgba(148,163,184,0.25)]" aria-hidden="true"></span>
          <span class="text-[#6e7f99] text-[0.82rem]">~{readingTime} min read</span>
        </div>

        <!-- Title -->
        <h1 class="text-[clamp(2.2rem,4.2vw,3.4rem)] leading-[1.05] tracking-[-0.04em] font-extrabold mb-6 max-w-[22ch]">
          {title}
        </h1>

        <!-- Summary -->
        <p class="text-[#a0afc4] text-[1.1rem] leading-[1.75] mb-8 max-w-[62ch]">
          {summary}
        </p>

        <!-- Stack tags -->
        <div class="flex flex-wrap gap-2 mb-8">
          {stack.map((item) => (
            <span class="inline-flex items-center min-h-8 px-3 py-1.5 rounded-full border border-[rgba(148,163,184,0.18)] bg-[rgba(148,163,184,0.07)] text-[#d8e0ec] text-[0.8rem] font-medium">
              {item}
            </span>
          ))}
        </div>

        <!-- External links -->
        {links && links.length > 0 && (
          <div class="flex flex-wrap gap-3">
            {links.map((link) => (
              <a href={link.href} target="_blank" rel="noopener" class="btn btn-secondary text-sm">
                {link.label}
                <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/>
                  <polyline points="15 3 21 3 21 9"/>
                  <line x1="10" y1="14" x2="21" y2="3"/>
                </svg>
              </a>
            ))}
          </div>
        )}

        <div class="mt-10 border-t border-[rgba(148,163,184,0.12)]"></div>
      </div>

      <!-- Two-column body -->
      <div class="article-body max-w-[860px] mx-auto flex gap-16 items-start">

        <!-- Sidebar ToC (desktop) -->
        {tocItems.length > 0 && (
          <aside class="toc-sidebar hidden lg:block w-[200px] flex-shrink-0 sticky top-[8rem] self-start">
            <p class="text-[0.7rem] font-bold tracking-[0.14em] uppercase text-[#6e7f99] mb-3">
              On this page
            </p>
            <nav aria-label="Table of contents">
              <ul class="grid gap-0.5 p-0 list-none">
                {tocItems.map((item) => (
                  <li>
                    <a
                      href={`#${item.slug}`}
                      class="toc-link block py-1.5 px-2 rounded-md text-[0.82rem] text-[#6e7f99] hover:text-[#f1f4f9] transition-colors duration-[180ms] leading-snug"
                      data-heading={item.slug}
                    >
                      {item.text}
                    </a>
                  </li>
                ))}
              </ul>
            </nav>
          </aside>
        )}

        <!-- Mobile ToC accordion -->
        {tocItems.length > 0 && (
          <details class="lg:hidden mb-8 glass p-0 overflow-hidden w-full">
            <summary class="flex items-center justify-between gap-3 px-5 py-4 cursor-pointer text-[0.82rem] font-semibold text-[#a0afc4] select-none list-none">
              <span class="flex items-center gap-2">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <line x1="3" y1="6" x2="21" y2="6"/>
                  <line x1="3" y1="12" x2="15" y2="12"/>
                  <line x1="3" y1="18" x2="18" y2="18"/>
                </svg>
                On this page
              </span>
              <svg class="toc-chevron w-4 h-4 transition-transform duration-200" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <polyline points="6 9 12 15 18 9"/>
              </svg>
            </summary>
            <nav class="px-5 pb-4 border-t border-[rgba(148,163,184,0.12)] pt-3" aria-label="Table of contents">
              <ul class="grid gap-1 p-0 list-none">
                {tocItems.map((item) => (
                  <li>
                    <a
                      href={`#${item.slug}`}
                      class="block py-1.5 text-[0.85rem] text-[#a0afc4] hover:text-[#f1f4f9] transition-colors duration-[180ms]"
                    >
                      {item.text}
                    </a>
                  </li>
                ))}
              </ul>
            </nav>
          </details>
        )}

        <!-- Prose content -->
        <div class="prose min-w-0 flex-1">
          <slot />
        </div>

      </div>

      <!-- Footer nav -->
      <div class="max-w-[860px] mx-auto mt-20 pt-8 border-t border-[rgba(148,163,184,0.12)]">
        <a
          href="/#projects"
          class="inline-flex items-center gap-2 text-[#a0afc4] hover:text-[#f1f4f9] transition-colors duration-[180ms] font-medium"
        >
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M19 12H5M12 5l-7 7 7 7"/>
          </svg>
          Back to all projects
        </a>
      </div>

    </main>
  </div>

  <script>
    // ── Reading progress bar ──────────────────────────────────────────────
    const bar = document.getElementById('progress-bar') as HTMLElement | null;

    const updateProgress = (): void => {
      if (!bar) return;
      const scrollTop = window.scrollY;
      const docHeight = document.documentElement.scrollHeight - window.innerHeight;
      const pct = docHeight > 0 ? (scrollTop / docHeight) * 100 : 0;
      bar.style.width = `${Math.min(pct, 100)}%`;
    };

    updateProgress();
    window.addEventListener('scroll', updateProgress, { passive: true });

    // ── Active ToC link highlighting ──────────────────────────────────────
    const tocLinks = document.querySelectorAll<HTMLAnchorElement>('a.toc-link');

    if (tocLinks.length > 0) {
      const headingEls = Array.from(tocLinks)
        .map((link) => {
          const id = link.getAttribute('data-heading');
          return id ? document.getElementById(id) : null;
        })
        .filter((el): el is HTMLElement => el !== null);

      const setActive = (id: string | null): void => {
        tocLinks.forEach((link) => {
          const isActive = link.getAttribute('data-heading') === id;
          link.classList.toggle('toc-link-active', isActive);
        });
      };

      const observer = new IntersectionObserver(
        (entries) => {
          // Find the topmost intersecting heading
          const visible = entries
            .filter((e) => e.isIntersecting)
            .sort((a, b) => a.boundingClientRect.top - b.boundingClientRect.top);

          if (visible.length > 0) {
            setActive(visible[0].target.id);
          }
        },
        { rootMargin: '0px 0px -70% 0px', threshold: 0 },
      );

      headingEls.forEach((el) => observer.observe(el));
    }

    // ── Mobile ToC: rotate chevron when open ─────────────────────────────
    const tocDetails = document.querySelector<HTMLDetailsElement>('details');
    const tocChevron = document.querySelector<SVGElement>('.toc-chevron');

    if (tocDetails && tocChevron) {
      tocDetails.addEventListener('toggle', () => {
        tocChevron.style.transform = tocDetails.open ? 'rotate(180deg)' : '';
      });
    }
  </script>
</BaseLayout>
