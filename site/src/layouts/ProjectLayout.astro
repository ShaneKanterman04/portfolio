---
import BaseLayout from './BaseLayout.astro';
import SiteHeader from '../components/SiteHeader.astro';
import StackBadge from '../components/StackBadge.astro';
import type { CollectionEntry } from 'astro:content';

interface Props {
  project: CollectionEntry<'projects'>;
}

const { project } = Astro.props;
const { title, summary, stack, status, date, links, heroImage, socialImage, role, scope, keyOutcome } = project.data;

const formatted = new Intl.DateTimeFormat('en-US', {
  year: 'numeric',
  month: 'long',
}).format(date);

const statusLabel: Record<string, string> = {
  shipped: 'Shipped',
  'in-progress': 'In Progress',
  archived: 'Archived',
};

const statusClass: Record<string, string> = {
  shipped: 'project-status-shipped',
  'in-progress': 'project-status-progress',
  archived: 'project-status-archived',
};

const wordCount = project.body?.split(/\s+/).filter(Boolean).length ?? 0;
const readingTime = Math.max(1, Math.ceil(wordCount / 200));

const headingMatches = project.body?.matchAll(/^##\s+(.+)$/gm) ?? [];
const tocItems: { text: string; slug: string }[] = [];
for (const match of headingMatches) {
  const text = match[1].trim();
  const slug = text
    .toLowerCase()
    .replace(/[^\w\s-]/g, '')
    .replace(/\s+/g, '-')
    .replace(/-+/g, '-')
    .replace(/^-|-$/g, '');
  tocItems.push({ text, slug });
}

const projectUrl = Astro.site ? new URL(`/projects/${project.id}/`, Astro.site).toString() : undefined;
const projectImagePath = socialImage ?? heroImage?.src ?? '/og/portfolio-preview.png';
const projectImageUrl = projectImagePath
  ? Astro.site
    ? new URL(projectImagePath, Astro.site).toString()
    : projectImagePath
  : undefined;

const structuredData = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: title,
  description: summary,
  datePublished: date.toISOString(),
  dateModified: date.toISOString(),
  image: projectImageUrl,
  mainEntityOfPage: projectUrl,
  author: {
    '@type': 'Person',
    name: 'Shane Kanterman',
    url: Astro.site?.toString() ?? 'https://shanekanterman.dev',
  },
  publisher: {
    '@type': 'Person',
    name: 'Shane Kanterman',
  },
  keywords: stack.join(', '),
};
---

<BaseLayout
  title={`${title} | Shane Kanterman`}
  description={summary}
  image={projectImagePath}
  imageAlt={`${title} project preview`}
  type="article"
  structuredData={structuredData}
>
  <div
    id="progress-bar"
    class="project-progress-bar fixed top-0 left-0 h-[2px] z-50 w-0 transition-none"
    aria-hidden="true"
  ></div>

  <div class="relative z-10 w-[min(calc(100%-2rem),1240px)] mx-auto pb-24">
    <SiteHeader backHref="/#projects" backLabel="All projects" />

    <main class="pt-10 max-[780px]:pt-6" id="main-content">
      <div class="max-w-[860px] mx-auto mb-12 max-[780px]:mb-7">
        <div class="flex flex-wrap items-center gap-x-4 gap-y-2 mb-7 max-[780px]:mb-4">
          <span class="text-[#71717a] text-[0.78rem] font-bold tracking-[0.16em] uppercase">
            Case Study
          </span>
          <span class="w-px h-3.5 bg-[rgba(0,0,0,0.12)]" aria-hidden="true"></span>
          <span class="text-[#71717a] text-[0.82rem]">{formatted}</span>
          <span class="w-px h-3.5 bg-[rgba(0,0,0,0.12)]" aria-hidden="true"></span>
          <span class:list={['inline-flex items-center gap-1.5 text-[0.8rem] font-medium', statusClass[status]]}>
            <span class="project-status-dot w-1.5 h-1.5 rounded-full flex-shrink-0"></span>
            {statusLabel[status]}
          </span>
          <span class="w-px h-3.5 bg-[rgba(0,0,0,0.12)]" aria-hidden="true"></span>
          <span class="text-[#71717a] text-[0.82rem]">~{readingTime} min read</span>
        </div>

        <h1 class="text-[clamp(2rem,4.2vw,3.4rem)] leading-[1.05] tracking-[-0.02em] font-extrabold mb-5 max-w-[22ch] text-[#18181b] max-[780px]:mb-3">
          {title}
        </h1>

        <p class="text-[#52525b] text-[1.1rem] leading-[1.75] mb-8 max-w-[62ch] max-[780px]:text-[1rem] max-[780px]:mb-5">
          {summary}
        </p>

        <div class="flex flex-wrap gap-2 mb-8 max-[780px]:mb-5">
          {stack.map((item) => (
            <StackBadge label={item} />
          ))}
        </div>

        <div class="project-detail-facts mb-8 max-[780px]:mb-5">
          <div>
            <p class="project-proof-label">Role</p>
            <p class="project-proof-copy">{role}</p>
          </div>
          <div>
            <p class="project-proof-label">Scope</p>
            <p class="project-proof-copy">{scope}</p>
          </div>
          <div>
            <p class="project-proof-label">Outcome</p>
            <p class="project-proof-copy">{keyOutcome}</p>
          </div>
        </div>

        {links && links.length > 0 && (
          <div class="flex flex-wrap gap-3">
            {links.map((link) => (
              <a href={link.href} target="_blank" rel="noopener noreferrer" class="btn btn-secondary text-sm">
                {link.label}
                <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6" />
                  <polyline points="15 3 21 3 21 9" />
                  <line x1="10" y1="14" x2="21" y2="3" />
                </svg>
              </a>
            ))}
          </div>
        )}

        <div class="mt-8 border-t border-[rgba(0,0,0,0.08)] max-[780px]:mt-6"></div>
      </div>

      <div class="article-body max-w-[860px] mx-auto flex gap-16 items-start">
        {tocItems.length > 0 && (
          <aside class="toc-sidebar hidden lg:block w-[200px] flex-shrink-0 sticky top-[8rem] self-start">
            <p class="text-[0.7rem] font-bold tracking-[0.14em] uppercase text-[#71717a] mb-3">
              On this page
            </p>
            <nav aria-label="Table of contents">
              <ul class="grid gap-0.5 p-0 list-none">
                {tocItems.map((item) => (
                  <li>
                    <a
                      href={`#${item.slug}`}
                      class="toc-link block py-1.5 px-2 rounded-md text-[0.82rem] text-[#71717a] hover:text-[#18181b] transition-colors duration-[180ms] leading-snug"
                      data-heading={item.slug}
                    >
                      {item.text}
                    </a>
                  </li>
                ))}
              </ul>
            </nav>
          </aside>
        )}

        <div class="min-w-0 flex-1">
          {tocItems.length > 0 && (
            <details class="lg:hidden mb-8 glass p-0 overflow-hidden w-full" data-toc-details>
              <summary class="flex items-center justify-between gap-3 px-5 py-4 cursor-pointer text-[0.82rem] font-semibold text-[#52525b] select-none list-none">
                <span class="flex items-center gap-2">
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <line x1="3" y1="6" x2="21" y2="6" />
                    <line x1="3" y1="12" x2="15" y2="12" />
                    <line x1="3" y1="18" x2="18" y2="18" />
                  </svg>
                  On this page
                </span>
                <svg class="toc-chevron w-4 h-4 transition-transform duration-200" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <polyline points="6 9 12 15 18 9" />
                </svg>
              </summary>
              <nav class="px-5 pb-4 border-t border-[rgba(0,0,0,0.08)] pt-3" aria-label="Table of contents">
                <ul class="grid gap-1 p-0 list-none">
                  {tocItems.map((item) => (
                    <li>
                      <a
                        href={`#${item.slug}`}
                        class="block py-1.5 text-[0.85rem] text-[#52525b] hover:text-[#18181b] transition-colors duration-[180ms]"
                      >
                        {item.text}
                      </a>
                    </li>
                  ))}
                </ul>
              </nav>
            </details>
          )}

          <div class="prose min-w-0 flex-1">
            <slot />
          </div>
        </div>
      </div>

      <div class="max-w-[860px] mx-auto mt-20 pt-8 border-t border-[rgba(0,0,0,0.08)]">
        <a
          href="/#projects"
          class="inline-flex items-center gap-2 text-[#52525b] hover:text-[#18181b] transition-colors duration-[180ms] font-medium"
        >
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M19 12H5M12 5l-7 7 7 7" />
          </svg>
          Back to all projects
        </a>
      </div>
    </main>
  </div>

  <script>
    const progressBar = document.getElementById('progress-bar');
    let progressFrame = 0;

    const updateProgress = () => {
      if (!progressBar) return;
      const scrollTop = window.scrollY;
      const docHeight = document.documentElement.scrollHeight - window.innerHeight;
      const pct = docHeight > 0 ? (scrollTop / docHeight) * 100 : 0;
      progressBar.style.width = `${Math.min(pct, 100)}%`;
      progressFrame = 0;
    };

    const requestProgressUpdate = () => {
      if (progressFrame !== 0) return;
      progressFrame = window.requestAnimationFrame(updateProgress);
    };

    updateProgress();
    window.addEventListener('scroll', requestProgressUpdate, { passive: true });

    const tocLinks = Array.from(document.querySelectorAll('a.toc-link'));

    if (tocLinks.length > 0 && 'IntersectionObserver' in window) {
      const headingEls = tocLinks
        .map((link) => {
          const id = link.getAttribute('data-heading');
          return id ? document.getElementById(id) : null;
        })
        .filter((el) => el instanceof HTMLElement);

      const setActive = (id) => {
        tocLinks.forEach((link) => {
          const isActive = link.getAttribute('data-heading') === id;
          link.classList.toggle('toc-link-active', isActive);
          if (isActive) {
            link.setAttribute('aria-current', 'location');
          } else {
            link.removeAttribute('aria-current');
          }
        });
      };

      const observer = new IntersectionObserver(
        (entries) => {
          const visible = entries
            .filter((entry) => entry.isIntersecting)
            .sort((a, b) => a.boundingClientRect.top - b.boundingClientRect.top);

          if (visible.length > 0) {
            setActive(visible[0].target.id);
          }
        },
        { rootMargin: '0px 0px -70% 0px', threshold: 0 },
      );

      headingEls.forEach((el) => observer.observe(el));
      if (headingEls[0]) setActive(headingEls[0].id);
    }

    const tocDetails = document.querySelector('[data-toc-details]');
    const tocChevron = document.querySelector('.toc-chevron');

    if (tocDetails instanceof HTMLDetailsElement && tocChevron instanceof SVGElement) {
      tocDetails.addEventListener('toggle', () => {
        tocChevron.style.transform = tocDetails.open ? 'rotate(180deg)' : '';
      });

      tocDetails.querySelectorAll('a').forEach((link) => {
        link.addEventListener('click', () => {
          tocDetails.open = false;
        });
      });
    }
  </script>
</BaseLayout>
